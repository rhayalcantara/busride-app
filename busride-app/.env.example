# Plantilla de secretos para docker-compose.yml — copiar a .env y completar.
# Generar valores fuertes, p. ej.:
#   SA_PASSWORD: openssl rand -base64 18   (añadir un símbolo; SQL Server exige
#                mínimo 8 caracteres con 3 de 4 categorías)
#   JWT_SECRET:  openssl rand -hex 32
# El compose falla explícitamente si faltan (sintaxis ${VAR:?}).
SA_PASSWORD=
JWT_SECRET=

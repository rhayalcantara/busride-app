NODE_ENV=development

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=busride_db
DB_USER=sa
DB_PASSWORD=BusRide@2024Secure!

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=cambia-esto-en-produccion-usa-un-secreto-largo
JWT_EXPIRES_IN=24h
# Días de vida del refresh token opaco (default 7)
REFRESH_TOKEN_DIAS=7

# Rate limiting global (ThrottlerGuard, B3): requests por ventana y ventana en ms.
# Defaults: 100 req / 60000 ms por IP. Los e2e lo suben vía env (ver test/utils).
THROTTLE_LIMIT=100
THROTTLE_TTL_MS=60000

# App
PORT=3000
CORS_ORIGIN=http://localhost:4200

NODE_ENV=development

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=busride_db
# Usuario de aplicación con privilegios mínimos (lo crea database/init/05_app_user.sql;
# su password es APP_DB_PASSWORD en busride-app/.env). No usar sa.
DB_USER=busride_app
DB_PASSWORD=pon-aqui-la-password-de-busride_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — mínimo 32 caracteres (validado al arranque); generar con: openssl rand -hex 32
JWT_SECRET=cambia-esto-usa-un-secreto-de-al-menos-32-caracteres
JWT_EXPIRES_IN=24h
# Días de vida del refresh token opaco (default 7)
REFRESH_TOKEN_DIAS=7

# Rate limiting global (ThrottlerGuard, B3): requests por ventana y ventana en ms.
# Defaults: 100 req / 60000 ms por IP. Los e2e lo suben vía env (ver test/utils).
THROTTLE_LIMIT=100
THROTTLE_TTL_MS=60000

# App
PORT=3000
CORS_ORIGIN=http://localhost:4200
